# Copy to .env.local and fill in. .env.local is git-ignored by Next.js.
# All four examples below use the same OpenAI-compatible adapter — switching
# providers is just changing these vars.

# Provider switch. Today only 'openai-compat' is implemented (covers Groq,
# Together, OpenRouter, DeepInfra, Fireworks, vLLM, LM Studio, Ollama, OpenAI).
LLM_PROVIDER=openai-compat

# --- Groq (default; sign up free at https://console.groq.com) ---
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=replace-me
LLM_MODEL=llama-3.3-70b-versatile

# --- Ollama (local, fully offline) ---
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.1

# --- Together.ai ---
# LLM_BASE_URL=https://api.together.xyz/v1
# LLM_API_KEY=...
# LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# --- OpenAI itself ---
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# Optional: cap server-side wait (ms). Default 30000.
# LLM_TIMEOUT_MS=30000
